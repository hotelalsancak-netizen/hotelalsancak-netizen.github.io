# Copy to .env and fill in.  .env is gitignored — never commit it.
# Prefer a dedicated read-only API user over a personal admin login: the API also
# exposes Insert/Update/Execute, and a 2FA-free API user is what lets cron run
# unattended.
ELEKTRA_URL=https://app.elektraweb.com
ELEKTRA_HOTELID=29481
ELEKTRA_USER=
ELEKTRA_PASS=

# Optional. The reservation view; defaults to the verified QA_HOTEL_RESERVATION.
#ELEKTRA_RES_OBJECT=QA_HOTEL_RESERVATION
# Optional. One-time code, if the account has two-factor auth enabled.
#ELEKTRA_AUTHCODE=
